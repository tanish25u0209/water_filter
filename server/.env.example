# --- HiveMQ MQTT (Cloud) ---
MQTT_BROKER_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
MQTT_TOPIC=water/device1/data

# --- Firebase Realtime Database ---
FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
# Base64-encode your service account JSON and paste it here (recommended, especially on Render).
# PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((Get-Content -Raw .\serviceAccount.json)))
# macOS/Linux: base64 -i serviceAccount.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# --- Server ---
PORT=4000
# Optional: restrict CORS to your dashboard's exact origin instead of allowing all origins (default "*")
CORS_ORIGIN=*

# --- Optional: only used by mqtt-publish-test.js for manual testing ---
TEST_TEMPERATURE=28.5
